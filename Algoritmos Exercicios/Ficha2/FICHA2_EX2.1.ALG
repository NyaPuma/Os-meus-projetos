Algoritmo "ficha2_ex2.1"
// Disciplina  :  [Linguagem e Lˇgica de ProgramašŃo]
// Professor   : Antonio Carlos Nicolodi
// DescrišŃo   : Aqui vocŕ descreve o que o programa faz! (funšŃo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 24/03/2026
Var
   // SecšŃo de Declaraš§es das varißveis
   nota:real
   x:inteiro
   saida:inteiro
Inicio
   // SecšŃo de Comandos, procedimento, funš§es, operadores, etc...

   x <- 1

   enquanto (x=1) faca
      escreval("Intruduza a nota:")
      leia(nota)
      se(nota>=90) e (nota<=100) entao
         escreval("Conceito A")
      senao
         se(nota>=80) e (nota<=89) entao
            Escreval("Conceito B")
         senao
            se(nota>=70) e (nota<=79) entao
               Escreval("Conceito C")
            senao
               se(nota>=60) e (nota<=69) entao
                  escreval("Conceito D")
               senao
                  se(nota>=0) e (nota<=59) entao
                     escreval("Conceito F")
                  senao
                     escreval("Nota invßlida")
                  fimse
               fimse
            fimse
         fimse
      fimse

      escreval("Deseja continuar, prima [1] para continuar, [0] para sair:")
      leia(saida)
      se (saida = 1) entao
         x <- 1
      senao
         se (saida = 0) entao
            x <- 0
         senao
            escreval("numero invßlido")
         fimse
      fimse
   fimenquanto


Fimalgoritmo